@startuml UC_Completo_VERTICAL
skinparam actorBackgroundColor #ADD1B2
skinparam usecaseBackgroundColor #E8F5E9
skinparam usecaseBorderColor #2E7D32
skinparam arrowColor #333333
skinparam packageBackgroundColor #F5F5F5

title Diagrama Completo de Casos de Uso: GuardianApp

top to bottom direction

actor Ciudadano
actor "Oficial de Seguridad"
actor Administrador

Ciudadano --|> "Oficial de Seguridad" : más funciones

rectangle "GuardianApp - Plataforma WebGIS de Reportes de Seguridad" #FFFFFF {

  package "Gestión de Usuarios" #E8F5E9 {
    usecase UC01 as "UC-01: Registrar"
    usecase UC02 as "UC-02: Login"
    usecase UC03 as "UC-03: Perfil"
    usecase UC04 as "UC-04: Completar"
  }

  package "Reportes de Incidentes" #FFF3E0 {
    usecase UC05 as "UC-05: Reportar"
    usecase UC06 as "UC-06: Adjuntar Evidencia"
    usecase UC07 as "UC-07: Georreferenciar"
    usecase UC08 as "UC-08: Guardar Borrador"
  }

  package "Visualización GIS" #E0F2F1 {
    usecase UC09 as "UC-09: Ver Mapa"
    usecase UC10 as "UC-10: Ver Incidentes"
    usecase UC11 as "UC-11: Filtrar"
    usecase UC12 as "UC-12: Buscar"
    usecase UC13 as "UC-13: Heatmap"
  }

  package "Análisis y Reportería" #FFFDE7 {
    usecase UC14 as "UC-14: Estadísticas"
    usecase UC15 as "UC-15: Generar Reportes"
    usecase UC16 as "UC-16: Exportar Datos"
  }

  package "Administración" #FCE4EC {
    usecase UC19 as "UC-19: Validar Reportes"
    usecase UC20 as "UC-20: Gestionar Usuarios"
    usecase UC21 as "UC-21: Configurar Sistema"
    usecase UC22 as "UC-22: Moderar Contenido"
    usecase UC23 as "UC-23: Reportes Admin"
  }
}

Ciudadano --> UC01: se registra
Ciudadano --> UC02: inicia sesión
Ciudadano --> UC05: reporta incidente
Ciudadano --> UC09: consulta mapa
Ciudadano --> UC14: ve estadísticas

"Oficial de Seguridad" --> UC09: visualiza mapa
"Oficial de Seguridad" --> UC10: ve incidentes
"Oficial de Seguridad" --> UC14: consulta estadísticas
"Oficial de Seguridad" --> UC15: genera reportes

Administrador --> UC14: analiza datos
Administrador --> UC15: genera reportes
Administrador --> UC19: valida reportes
Administrador --> UC20: gestiona usuarios
Administrador --> UC21: configura sistema

@enduml
